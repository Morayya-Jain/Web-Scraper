# Australian Graduate Job Finder — environment variables
# Copy this file to `.env` and fill in the keys you have. Any source whose
# keys are missing is silently skipped, so you can run a partial pipeline.

# --- Layer A (aggregator APIs) ---

# Adzuna  -  https://developer.adzuna.com  (free, ~250 calls/day)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble  -  https://jooble.org/api/about  (free key on request)
JOOBLE_API_KEY=

# Careerjet  -  https://www.careerjet.com/partners/api/  (free affid on signup)
CAREERJET_AFFID=

# --- Optional: Claude screening for visa eligibility + fit ranking ---
# Get a key at https://console.anthropic.com  -  if absent, the pipeline falls
# back to a free keyword pre-filter.
ANTHROPIC_API_KEY=

# --- Optional: where to write outputs (defaults to current dir) ---
OUTPUT_DIR=.
